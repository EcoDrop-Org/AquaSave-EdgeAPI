# URL del broker MQTT.
# HiveMQ Cloud usa MQTT sobre TLS (mqtts) en el puerto 8883.
MQTT_BROKER_URL=mqtts://109a1a97e0814454afa8d22b818e2da5.s1.eu.hivemq.cloud:8883

# Credenciales MQTT creadas en HiveMQ Cloud > Access Management.
MQTT_USERNAME=aquasave-edge
MQTT_PASSWORD=

# Opcional. Si no se define, se genera uno automaticamente.
MQTT_CLIENT_ID=aquasave-edge-service

# Opcional. Mantener true/omitido en Render; usar false solo si necesitas
# desactivar validacion TLS para pruebas puntuales.
MQTT_REJECT_UNAUTHORIZED=true

# URL base del backend AquaSave
BACKEND_BASE_URL=https://aquasave-backend.onrender.com

# API key para los endpoints /api/edge del backend.
# Debe coincidir con EDGE_API_KEY del backend (si el backend no la define,
# dejar vacio).
EDGE_API_KEY=

# Cada cuantos ms se consultan comandos pendientes al backend
COMMAND_POLL_INTERVAL_MS=3000
